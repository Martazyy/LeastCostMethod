<Window x:Class="LeastCostMethodApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Решение транспортной задачи — Метод минимальных элементов" 
        Height="680" Width="980"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Стили для TextBlock и Button -->
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель — Параметры -->
        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="Параметры транспортной задачи" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>

            <GroupBox Header="Размеры матрицы" Margin="0,15,0,10">
                <StackPanel Margin="10">
                    <TextBlock Text="Количество поставщиков (строк):"/>
                    <TextBox x:Name="TxtNumSuppliers" Text="3" Margin="0,4"/>

                    <TextBlock Text="Количество потребителей (столбцов):"/>
                    <TextBox x:Name="TxtNumConsumers" Text="5" Margin="0,4"/>

                    <Button Content="Создать / Обновить матрицу стоимостей" 
                            Click="BtnCreateCostMatrix_Click"
                            Background="#3498DB" Foreground="White"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Запасы и потребности" Margin="0,10">
                <StackPanel Margin="10">
                    <TextBlock Text="Запасы поставщиков (через запятую):"/>
                    <TextBox x:Name="TxtSupply" ToolTip="Пример: 200,350,300" Margin="0,4"/>

                    <TextBlock Text="Потребности потребителей (через запятую):"/>
                    <TextBox x:Name="TxtDemand" ToolTip="Пример: 270,130,190,150,110" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <UniformGrid Columns="2" Margin="0,15">
                <Button Content="Решить" 
                        Click="BtnSolve_Click"
                        Background="#2ECC71" Foreground="White" FontWeight="Bold"/>
                <Button Content="Очистить всё" 
                        Click="BtnClear_Click"
                        Background="#E74C3C" Foreground="White"/>
            </UniformGrid>

            <GroupBox Header="Работа с файлами" Margin="0,20,0,0">
                <UniformGrid Columns="2" Margin="10">
                    <Button Content="Загрузить из файла" Click="BtnLoadFromFile_Click"/>
                    <Button Content="Сохранить решение" Click="BtnSaveResult_Click"/>
                </UniformGrid>
            </GroupBox>
        </StackPanel>

        <!-- Правая панель — Результаты -->
        <StackPanel Grid.Column="1">
            <TextBlock Text="Матрица стоимостей" FontSize="15" FontWeight="Bold"/>
            <DataGrid x:Name="DataGridCost" 
                      Height="260" 
                      Margin="0,8"
                      AutoGenerateColumns="True"
                      CanUserAddRows="False"
                      GridLinesVisibility="All"/>

            <TextBlock Text="Результат решения" FontSize="15" FontWeight="Bold" Margin="0,15,0,8"/>
            <ScrollViewer Height="280" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TxtResult" 
                           FontFamily="Consolas" 
                           FontSize="13"
                           TextWrapping="Wrap"
                           Background="White"
                           Padding="10"/>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Window>